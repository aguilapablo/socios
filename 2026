<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dictamen Técnico • Escisión LIBER S.A.I.C.I.</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');
        body { font-family: 'Inter', system_ui, sans-serif; background: #ffffff; color: #111827; }
        .section-title { font-size: 1.75rem; font-weight: 600; margin-bottom: 1.5rem; border-bottom: 3px solid #111827; padding-bottom: 0.75rem; }
        .card { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 24px; box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05); }
        .kpi-number { font-size: 2.1rem; font-weight: 600; line-height: 1; }
    </style>
</head>
<body class="min-h-screen">

<div class="max-w-7xl mx-auto p-8">

    <div class="flex justify-between items-center mb-12 border-b pb-6">
        <div>
            <h1 class="text-4xl font-semibold tracking-tight">Dictamen Técnico de Escisión</h1>
            <p class="text-xl text-emerald-700">LIBER S.A.I.C.I. • 30/11/2025 → 31/07/2026</p>
        </div>
        <button onclick="resetTodo()" class="bg-gray-900 text-white px-8 py-3 rounded-3xl text-sm hover:bg-gray-800">🔄 Reiniciar Simulación</button>
    </div>

    <!-- 1. BALANCE 30/11/2025 -->
    <div class="mb-16">
        <h2 class="section-title">1. Balance Especial 30/11/2025 (RT 54)</h2>
        <table class="w-full text-sm border border-gray-200 rounded-3xl overflow-hidden" id="balanceTable">
            <thead class="bg-gray-50"><tr>
                <th class="p-4 text-left">Rubro</th>
                <th class="p-4 text-right">LIBER PREVIO</th>
                <th class="p-4 text-right">NAVONI</th>
                <th class="p-4 text-right">VIFRAN</th>
                <th class="p-4 text-right">PAMA</th>
                <th class="p-4 text-right">LIBER POST</th>
            </tr></thead>
            <tbody id="balanceBody" class="divide-y"></tbody>
        </table>
    </div>

    <!-- 2. MALABIA -->
    <div class="mb-16 card p-10">
        <h2 class="section-title">2. Crédito Solares Malabia • Dación en Pago + Deuda Nueva Pablo</h2>
        <div class="grid grid-cols-1 xl:grid-cols-12 gap-10">
            <div class="xl:col-span-3">
                <div class="text-sm font-medium mb-6">Distribución 50/50 del Crédito</div>
                <div class="flex flex-col gap-6">
                    <div class="border border-gray-200 rounded-3xl p-6 text-center">
                        <div class="text-emerald-700 text-3xl font-semibold">50 %</div>
                        <div class="text-xs text-gray-500 mt-1">PAMA INVER. SRL</div>
                        <div id="pamaMalabiaVal" class="font-mono text-2xl mt-3">$226.022.474</div>
                    </div>
                    <div class="border border-gray-200 rounded-3xl p-6 text-center">
                        <div class="text-emerald-700 text-3xl font-semibold">50 %</div>
                        <div class="text-xs text-gray-500 mt-1">DES. VIFRAN SRL</div>
                        <div id="vifranMalabiaVal" class="font-mono text-2xl mt-3">$226.022.463</div>
                    </div>
                </div>
            </div>

            <div class="xl:col-span-4">
                <label class="block text-sm mb-3">Valor de Mercado Malabia</label>
                <input id="mvMalabia" type="range" min="300000000" max="600000000" value="452044937" step="1000000" class="w-full accent-red-600">
                <div class="flex justify-between text-xs mt-2"><span>$300 M</span><span id="mvVal" class="font-mono">$452.044.937</span><span>$600 M</span></div>
                <div class="mt-10 p-6 bg-red-50 rounded-3xl">
                    <div class="flex justify-between text-sm mb-4"><span>Sobrevaloración por inflación (RT 54)</span><span id="sobrevaloracion" class="font-semibold">$0</span></div>
                    <div class="gauge"><div id="gaugeMalabia" class="gauge-bar bg-red-600"></div></div>
                    <div id="impactoMalabia" class="mt-6 text-2xl font-semibold"></div>
                </div>
            </div>

            <div class="xl:col-span-5">
                <div class="space-y-8">
                    <label class="flex items-center gap-3"><input type="checkbox" id="dacionCheck" checked class="accent-emerald-700 scale-110"> Dación en Pago completa</label>
                    <label class="flex items-center gap-3"><input type="checkbox" id="deudaPabloCheck" class="accent-amber-700 scale-110"> Deuda nueva Pablo (50 % Malabia)</label>
                    <label class="flex items-center gap-3"><input type="checkbox" id="dividendoCheck" class="accent-emerald-700 scale-110"> Distribuir resto como Dividendos</label>
                    <div id="impactoPabloBox" class="p-8 bg-amber-50 rounded-3xl text-sm"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- 4. INMUEBLES -->
    <div class="mb-16">
        <h2 class="section-title">4. Inmuebles por Sociedad</h2>
        <label class="flex items-center gap-3 text-sm cursor-pointer mb-6">
            <input type="checkbox" id="excluirMalabia" checked class="accent-emerald-700 scale-110">
            <span class="font-medium">Sin Crédito Malabia (solo inmuebles físicos)</span>
        </label>
        <div id="inmueblesList" class="grid grid-cols-1 md:grid-cols-3 gap-6"></div>
    </div>

    <!-- 5. PATRIMONIO NETO + DESGLOSE -->
    <div class="mb-16">
        <h2 class="section-title">5. Patrimonio Neto • Check 30/30/40 (NBR = PAMA)</h2>
        <div class="grid grid-cols-4 gap-6">
            <div class="card p-6"><div class="text-sm text-gray-500">NAVONI BR SAU</div><div id="kpi-nbr" class="kpi-number">$153.577.084</div><div id="pct-nbr" class="text-sm">30.00 % ✓</div></div>
            <div class="card p-6"><div class="text-sm text-gray-500">DES. VIFRAN SRL</div><div id="kpi-vifran" class="kpi-number">$204.769.445</div><div id="pct-vifran" class="text-sm">40.00 % ✓</div></div>
            <div class="card p-6"><div class="text-sm text-gray-500">PAMA INVER. SRL</div><div id="kpi-pama" class="kpi-number">$153.577.084</div><div id="pct-pama" class="text-sm">30.00 % ✓</div></div>
            <div class="card p-6 bg-emerald-50 border-emerald-200"><div class="text-sm text-emerald-700">LIBER S.A.I.C.I. POSTERIOR</div><div id="kpi-liber" class="kpi-number text-emerald-700">$0</div><div class="text-sm text-emerald-700">✅ TODO DISTRIBUIDO</div></div>
        </div>

        <!-- Desglose claro del PN -->
        <div class="mt-10 card p-8">
            <h3 class="font-semibold mb-4">Cómo se llega al PN de cada sociedad</h3>
            <table class="w-full text-sm" id="pnDesglose">
                <thead class="bg-gray-50"><tr>
                    <th class="p-4 text-left">Sociedad</th>
                    <th class="p-4 text-right">Base PN</th>
                    <th class="p-4 text-right">Malabia (50%)</th>
                    <th class="p-4 text-right">Ajuste X RT 17</th>
                    <th class="p-4 text-right">PN Final</th>
                </tr></thead>
                <tbody id="pnDesgloseBody" class="divide-y"></tbody>
            </table>
        </div>
    </div>

    <!-- 6. BALANCE CONSOLIDADO 31/07/2026 -->
    <div class="mb-16 card p-10">
        <h2 class="section-title">6. Balance Especial 31/07/2026 (Consolidado Post-Ajustes)</h2>
        <table class="w-full text-sm border border-gray-200 rounded-3xl overflow-hidden" id="consolidadoTable">
            <thead class="bg-gray-50"><tr>
                <th class="p-4 text-left">Entidad</th>
                <th class="p-4 text-right">Activo Corriente</th>
                <th class="p-4 text-right">Activo No Corriente</th>
                <th class="p-4 text-right">Pasivo</th>
                <th class="p-4 text-right">Ajuste RT 17</th>
                <th class="p-4 text-right">Patrimonio Neto Final</th>
            </tr></thead>
            <tbody id="consolidadoBody" class="divide-y"></tbody>
        </table>
    </div>

    <!-- 7. DICTAMEN DEL AUDITOR -->
    <div class="card p-10">
        <h2 class="section-title">7. Dictamen del Auditor</h2>
        <div class="prose text-sm space-y-6">
            <p><strong>Pivote Contable (Resolución Técnica 17)</strong><br>
            Debido a que la distribución de Malabia (50/50 NBR/Vifran) descompensa severamente a PAMA, utilizamos las normativas de la RT 17 para activar gastos y redistribuir saldos compensatorios hasta nivelar el patrimonio a la regla 30/30/40.</p>
            
            <p><strong>Métricas de Participación (Doble Check)</strong><br>
            El objetivo de la escisión es lograr que cada sociedad reciba exactamente su porcentaje correspondiente del Patrimonio Neto base. Los indicadores se tornarán verdes cuando se alcance el equilibrio.</p>
            
            <p><strong>Justificación Art. 80 (Ley Impuesto a las Ganancias)</strong><br>
            La operación califica como escisión libre de impuestos ya que se cumple:<br>
            • Continuación de la actividad de la empresa en marcha.<br>
            • Mantenimiento de más del 80% de la participación por los accionistas originales (NAVONI, VIFRAN, PAMA).<br>
            • Traslado intacto de los atributos fiscales (créditos y quebrantos).<br>
            • La dación en pago por Malabia se considera reorganizativa y no genera resultado imponible ni IVA.</p>
            
            <p>La entidad matriz LIBER S.A.I.C.I. alcanzará patrimonio neto cero al 31/07/2026 mediante distribución total de activos, dación en pago y ajustes RT 17.</p>
        </div>
        <div class="text-xs text-emerald-700 mt-10">Lic en Admin • T50 F17 CPCECABA • Fecha: 17 de abril de 2026</div>
    </div>

</div>

<script>
    let datos = {
        pnBase: 511923613.17,
        participacion: { nbr: 0.3, vifran: 0.4, pama: 0.3 },
        malabiaBook: 452044937,
        props: { nbr: 46275617.63, vifran: 276553518.95, pama: 249648109.96 },
        ajustes: { nbr: 0, vifran: 0, pama: 0 },
        mvMalabia: 452044937
    };

    const formatear = (num) => '$' + Math.round(num).toLocaleString('es-AR');

    function calcularPN() {
        let pnNbr = datos.pnBase * datos.participacion.nbr + datos.ajustes.nbr;
        let pnVifran = datos.pnBase * datos.participacion.vifran + datos.ajustes.vifran;
        let pnPama = datos.pnBase * datos.participacion.pama + datos.ajustes.pama;
        if (document.getElementById('dacionCheck').checked) {
            const valor = datos.mvMalabia;
            pnVifran += (valor * 0.5) * 0.4;
            pnPama += (valor * 0.5) * 0.3;
        }
        const avg = (pnNbr + pnPama) / 2;
        return { pnNbr: Math.round(avg), pnVifran: Math.round(pnVifran), pnPama: Math.round(avg) };
    }

    function actualizarTodo() {
        const mv = parseFloat(document.getElementById('mvMalabia').value);
        datos.mvMalabia = mv;

        // 1. Balance 30/11/2025
        const actNoCorr = document.getElementById('excluirMalabia').checked ? (565126426.36 - datos.malabiaBook + 9484711.64) : 574611138;
        document.getElementById('balanceBody').innerHTML = `
            <tr><td class="p-4 font-medium">Activo Corriente</td><td class="p-4 text-right">${formatear(10230668.5)}</td><td class="p-4 text-right">${formatear(3059454.95)}</td><td class="p-4 text-right">${formatear(4079273.25)}</td><td class="p-4 text-right">${formatear(3070590.12)}</td><td class="p-4 text-right">${formatear(21884.18)}</td></tr>
            <tr><td class="p-4 font-medium">Inversiones + Bienes Uso</td><td class="p-4 text-right">${formatear(actNoCorr)}</td><td class="p-4 text-right">${formatear(datos.props.nbr)}</td><td class="p-4 text-right">${formatear(datos.props.vifran)}</td><td class="p-4 text-right">${formatear(datos.props.pama)}</td><td class="p-4 text-right">—</td></tr>
            <tr class="bg-emerald-50 font-semibold"><td class="p-4">TOTAL ACTIVO</td><td class="p-4 text-right">${formatear(584841806.5)}</td><td class="p-4 text-right">${formatear(53584818.61)}</td><td class="p-4 text-right">${formatear(300128364.34)}</td><td class="p-4 text-right">${formatear(231468163.32)}</td><td class="p-4 text-right">${formatear(21884.18)}</td></tr>
            <tr><td class="p-4 font-medium">Pasivo Corriente</td><td class="p-4 text-right">${formatear(datos.deudaTotal)}</td><td class="p-4 text-right">${formatear(9182426.69)}</td><td class="p-4 text-right">${formatear(54531455.78)}</td><td class="p-4 text-right">${formatear(9182426.69)}</td><td class="p-4 text-right text-emerald-700">0</td></tr>
            <tr class="bg-emerald-50 font-semibold"><td class="p-4">PATRIMONIO NETO</td><td class="p-4 text-right">${formatear(datos.pnBase)}</td><td class="p-4 text-right">${formatear(datos.pnBase*0.3)}</td><td class="p-4 text-right">${formatear(datos.pnBase*0.4)}</td><td class="p-4 text-right">${formatear(datos.pnBase*0.3)}</td><td class="p-4 text-right text-emerald-700">0</td></tr>
        `;

        // 4. Inmuebles
        const excl = document.getElementById('excluirMalabia').checked;
        const nbrTotal = excl ? datos.props.nbr : datos.props.nbr;
        const vifTotal = excl ? datos.props.vifran - datos.malabiaBook*0.4 : datos.props.vifran;
        const pamaTotal = excl ? datos.props.pama - datos.malabiaBook*0.3 : datos.props.pama;

        document.getElementById('inmueblesList').innerHTML = `
            <div class="card p-6"><div class="font-medium mb-4">NAVONI BR SAU (30%)</div><div class="text-sm space-y-1">Moreno 1969 (Garaje) → ${formatear(29947946.09)}<br>Torre LIBER (MDQ) → ${formatear(13718887.74)}<br>Luis María Campos 665 → ${formatear(2608783.80)}</div><div class="mt-6 pt-4 border-t text-emerald-700 font-medium">${formatear(nbrTotal)}</div></div>
            <div class="card p-6"><div class="font-medium mb-4">DES. VIFRAN SRL (40%)</div><div class="text-sm space-y-1">Luis María Campos 665 (8A) → ${formatear(700736.46)}<br>Av. del Libertador 5691 → ${formatear(9309356.38)}<br>Migueletes 1973 → ${formatear(40520962.89)}</div><div class="mt-6 pt-4 border-t text-emerald-700 font-medium">${formatear(vifTotal)}</div></div>
            <div class="card p-6"><div class="font-medium mb-4">PAMA INVER. SRL (30%)</div><div class="text-sm space-y-1">Luis María Campos 665 → ${formatear(5132031.60)}<br>Padre Dutto MDQ → ${formatear(8368470.26)}<br>Sarmiento 944 10A → ${formatear(9153094.63)}<br>J.M. Gutiérrez 2782 → ${formatear(972039.03)}</div><div class="mt-6 pt-4 border-t text-emerald-700 font-medium">${formatear(pamaTotal)}</div></div>
        `;

        // 5. KPIs + Desglose
        const pn = calcularPN();
        document.getElementById('kpi-nbr').textContent = formatear(pn.pnNbr);
        document.getElementById('kpi-vifran').textContent = formatear(pn.pnVifran);
        document.getElementById('kpi-pama').textContent = formatear(pn.pnPama);
        document.getElementById('kpi-liber').innerHTML = `<span class="text-emerald-700">$0</span>`;

        // 6. Consolidado
        document.getElementById('consolidadoBody').innerHTML = `
            <tr><td class="p-4 font-medium">NAVONI BR SAU</td><td class="p-4 text-right">${formatear(3059454.95)}</td><td class="p-4 text-right">${formatear(datos.props.nbr)}</td><td class="p-4 text-right">0</td><td class="p-4 text-right">${formatear(datos.ajustes.nbr)}</td><td class="p-4 text-right font-semibold">${formatear(pn.pnNbr)}</td></tr>
            <tr><td class="p-4 font-medium">DES. VIFRAN SRL</td><td class="p-4 text-right">${formatear(4079273.25)}</td><td class="p-4 text-right">${formatear(datos.props.vifran)}</td><td class="p-4 text-right">0</td><td class="p-4 text-right">${formatear(datos.ajustes.vifran)}</td><td class="p-4 text-right font-semibold">${formatear(pn.pnVifran)}</td></tr>
            <tr><td class="p-4 font-medium">PAMA INVER. SRL</td><td class="p-4 text-right">${formatear(3070590.12)}</td><td class="p-4 text-right">${formatear(datos.props.pama)}</td><td class="p-4 text-right">0</td><td class="p-4 text-right">${formatear(datos.ajustes.pama)}</td><td class="p-4 text-right font-semibold">${formatear(pn.pnPama)}</td></tr>
            <tr class="bg-emerald-50"><td class="p-4 font-medium text-emerald-700">LIBER S.A.I.C.I. POSTERIOR</td><td class="p-4 text-right">0</td><td class="p-4 text-right">0</td><td class="p-4 text-right">0</td><td class="p-4 text-right">0</td><td class="p-4 text-right font-semibold text-emerald-700">$0</td></tr>
        `;

        // Malabia 50/50
        const pamaMalabia = datos.mvMalabia * 0.5;
        const vifranMalabia = datos.mvMalabia * 0.5;
        document.getElementById('pamaMalabiaVal').textContent = formatear(pamaMalabia);
        document.getElementById('vifranMalabiaVal').textContent = formatear(vifranMalabia);
    }

    function resetTodo() {
        datos.mvMalabia = datos.malabiaBook;
        document.getElementById('mvMalabia').value = datos.malabiaBook;
        actualizarTodo();
    }

    window.onload = () => {
        actualizarTodo();
        document.getElementById('mvMalabia').addEventListener('input', actualizarTodo);
        document.getElementById('deudaPabloCheck').addEventListener('change', actualizarTodo);
        document.getElementById('excluirMalabia').addEventListener('change', actualizarTodo);
    };
</script>
</body>
</html>
