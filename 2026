<script>
  const fmt = n => '$' + Math.round(n).toLocaleString('es-AR');
  const VH    = 452044937;
  const PASIVO = 72918193;

  function calcular() {
    const mv   = parseFloat(document.getElementById('mvSlider').value)  || VH;
    const tL   = parseFloat(document.getElementById('tasaLuis').value)  || 40;
    const perL = parseInt(document.getElementById('perLuis').value)     || 3;

    // Luis+Jose: capital actualizado con tasa e interés compuesto trimestral
    const luisDeuda  = PASIVO * Math.pow(1 + tL / 100 / 4, perL);
    // Pablo: lo que falta para cubrir el VNR una vez imputada la deuda Luis
    // Si VNR <= luisDeuda, Pablo = 0 (Luis lo cubre todo con su deuda)
    const pabloDeuda = Math.max(0, mv - luisDeuda);
    const total      = luisDeuda + pabloDeuda;

    // ── Sección 3: slider y distribución 50/50 ──────────────────────────────
    document.getElementById('mvDisplay').textContent   = fmt(mv);
    document.getElementById('pamaPart').textContent    = fmt(mv * 0.5);
    document.getElementById('vifranPart').textContent  = fmt(mv * 0.5);

    // Status box dinámico — test de recuperabilidad RT 54
    const dif = mv - VH;
    const box = document.getElementById('statusBox');
    const lbl = document.getElementById('sbLabel');
    const val = document.getElementById('sbVal');
    if (dif > 500) {
      box.className = 'status-box positive';
      lbl.className = 'sb-label positive';
      lbl.textContent = 'Superávit de Mercado (Plusvalía)';
      val.className = 'sb-val positive';
      val.textContent = '+' + fmt(dif);
    } else if (dif < -500) {
      box.className = 'status-box negative';
      lbl.className = 'sb-label negative';
      lbl.textContent = 'Pérdida por Desvalorización (Recuperabilidad)';
      val.className = 'sb-val negative';
      val.textContent = fmt(dif);
    } else {
      box.className = 'status-box neutral';
      lbl.className = 'sb-label neutral';
      lbl.textContent = 'Valor Técnico RT 54 — Sin variación';
      val.className = 'sb-val neutral';
      val.textContent = fmt(mv);
    }

    // Panel dación oscuro
    document.getElementById('rPablo').textContent       = fmt(pabloDeuda);
    document.getElementById('rLuis').textContent        = fmt(luisDeuda);
    document.getElementById('impactoPablo').textContent = fmt(pabloDeuda);
    document.getElementById('impactoLuis').textContent  = fmt(luisDeuda);

    // ── Sección 5: detalle dación en pago ──────────────────────────────────
    document.getElementById('dacionMv').textContent    = fmt(mv);
    document.getElementById('dacionLuis').textContent  = fmt(luisDeuda);
    document.getElementById('dacionPablo').textContent = fmt(pabloDeuda);

    // ── Sección 6: verificación de cálculos ────────────────────────────────
    document.getElementById('verifLuis').textContent  = fmt(luisDeuda);
    document.getElementById('verifPablo').textContent = fmt(pabloDeuda);
    document.getElementById('verifTotal').textContent = fmt(total);

    // ── Sección 11: balance proyectado — deuda Pablo dinámica ───────────────
    // La celda muestra el escenario activo según el VNR
    const proyPablo = document.getElementById('proy-pablo');
    if (proyPablo) {
      if (pabloDeuda > 0) {
        proyPablo.textContent = fmt(pabloDeuda);
        proyPablo.style.color = 'var(--gold)';
      } else {
        // VNR <= luisDeuda: Luis cubre todo, Pablo = $0
        proyPablo.textContent = '$0 · Luis cubre el total';
        proyPablo.style.color = 'var(--accent2)';
      }
    }

    // ── Escenario label en Sección 11 ──────────────────────────────────────
    const escLabel = document.getElementById('escenario-label');
    if (escLabel) {
      if (mv > luisDeuda) {
        escLabel.textContent  = 'Escenario activo: VNR > Deuda Luis — Pablo cubre el remanente';
        escLabel.style.color  = 'var(--gold)';
      } else if (Math.abs(mv - luisDeuda) <= 500) {
        escLabel.textContent  = 'Escenario activo: VNR = Deuda Luis — Pablo = $0, Luis cobra todo';
        escLabel.style.color  = 'var(--accent2)';
      } else {
        escLabel.textContent  = 'Escenario activo: VNR < Deuda Luis — pérdida parcial en el crédito';
        escLabel.style.color  = 'var(--danger)';
      }
    }
  }

  window.addEventListener('load', calcular);
</script>

