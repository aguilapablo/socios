*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0f1e35;
  --accent:#00c389;
  --accent2:#00a372;
  --gold:#c9a84c;
  --indigo:#4f46e5;
  --text:#0f1e35;
  --text2:#4a5568;
  --text3:#8896a7;
  --surface:#ffffff;
  --surface2:#f4f7fb;
  --surface3:#eaf0f8;
  --border:#dde4ef;
  --border2:#c8d4e4;
  --danger:#e53e3e;
}
@media(prefers-color-scheme:dark){
  :root{
    --text:#e8edf4;--text2:#9dafc5;--text3:#5d7290;
    --surface:#0f1e35;--surface2:#162844;--surface3:#1e3554;
    --border:#1e3554;--border2:#243e60;--navy:#0a1625;
  }
}
body{font-family:'Inter',system-ui,sans-serif;background:var(--surface2);color:var(--text);font-size:13px;line-height:1.5;-webkit-font-smoothing:antialiased}
.shell{max-width:1080px;margin:0 auto;padding:24px 20px 56px}

/* ─── HEADER ─── */
.hdr{background:var(--navy);border-radius:16px;padding:36px 40px;margin-bottom:28px;position:relative;overflow:hidden}
.hdr::before{content:"";position:absolute;top:-60px;right:-60px;width:260px;height:260px;border-radius:50%;background:rgba(0,195,137,.07)}
.hdr::after{content:"";position:absolute;bottom:-80px;right:80px;width:180px;height:180px;border-radius:50%;background:rgba(201,168,76,.05)}
.hdr-eyebrow{font-size:10px;font-weight:700;color:var(--accent);letter-spacing:.18em;text-transform:uppercase;margin-bottom:10px}
.hdr-top{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:8px}
.hdr-title{font-size:26px;font-weight:800;color:#ffffff;letter-spacing:-.03em;margin-bottom:6px}
.hdr-sub{font-size:12px;color:rgba(255,255,255,.4)}
.hdr-date-box{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:14px 20px;text-align:right;flex-shrink:0}
.hdr-date-label{font-size:9px;font-weight:700;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px}
.hdr-date-val{font-size:13px;font-weight:600;color:#ffffff}
.hdr-date-status{font-size:10px;color:var(--accent);font-weight:500;margin-top:5px}
.hdr-badge{background:rgba(0,195,137,.15);border:1px solid rgba(0,195,137,.3);border-radius:6px;padding:4px 10px;font-size:10px;font-weight:600;color:var(--accent);letter-spacing:.08em;display:inline-block;margin-top:14px}
.hdr-meta{display:flex;gap:24px;margin-top:20px;padding-top:18px;border-top:1px solid rgba(255,255,255,.07);flex-wrap:wrap}
.hdr-meta-item{display:flex;align-items:center;gap:6px;font-size:11px;color:rgba(255,255,255,.38)}
.hdr-meta-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);opacity:.7}

/* ─── LABELS ─── */
.sec-label{font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:10px;padding-left:2px}
.sec-title{font-size:15px;font-weight:700;color:var(--text);letter-spacing:-.01em;display:flex;align-items:center;gap:10px;margin-bottom:16px}
.sec-title::before{content:"";width:4px;height:18px;background:var(--accent);border-radius:3px;flex-shrink:0}
.sec-title.indigo::before{background:var(--indigo)}

/* ─── KPI ─── */
.kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-bottom:28px}
.kpi-grid-5{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:12px;margin-bottom:28px}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px 18px;position:relative;overflow:hidden}
.kpi::after{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent);border-radius:2px 2px 0 0}
.kpi.gold::after{background:var(--gold)}
.kpi.indigo-card::after{background:var(--indigo)}
.kpi.navy-card{background:var(--navy);border-color:transparent}
.kpi.navy-card::after{background:var(--accent)}
.kpi.green-card{background:rgba(0,195,137,.06);border-color:rgba(0,195,137,.25)}
.kpi.green-card::after{background:var(--accent)}
.kpi-label{font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--text3);margin-bottom:10px}
.kpi.navy-card .kpi-label{color:rgba(255,255,255,.38)}
.kpi-value{font-size:19px;font-weight:800;color:var(--text);letter-spacing:-.03em;margin-bottom:4px;font-variant-numeric:tabular-nums}
.kpi.navy-card .kpi-value{color:#ffffff}
.kpi.green-card .kpi-value{color:var(--accent2)}
.kpi-sub{font-size:10px;color:var(--text3)}
.kpi.navy-card .kpi-sub{color:rgba(255,255,255,.32)}
.kpi-badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;padding:2px 7px;border-radius:4px;font-weight:600;margin-top:6px}
.badge-green{background:rgba(0,195,137,.1);color:var(--accent2)}
.badge-gold{background:rgba(201,168,76,.1);color:var(--gold)}
.badge-indigo{background:rgba(79,70,229,.1);color:var(--indigo)}

/* ─── CARDS ─── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px}
.card-sm{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 18px}
.card.indigo-left{border-left:5px solid var(--indigo);border-radius:0 12px 12px 12px;padding-left:28px}
.grid-2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
.grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}
.mb8{margin-bottom:8px}
.mb20{margin-bottom:20px}
.mb28{margin-bottom:28px}
.row{display:flex;gap:16px}
.row>*{flex:1;min-width:0}

/* ─── TABLES ─── */
table{width:100%;border-collapse:separate;border-spacing:0}
thead tr th{background:var(--surface2);font-size:9.5px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--text3);padding:10px 14px;border-bottom:2px solid var(--surface3)}
thead tr th:first-child{border-radius:8px 0 0 0}
thead tr th:last-child{border-radius:0 8px 0 0}
tbody tr td{padding:11px 14px;border-bottom:1px solid var(--border);font-size:12px;color:var(--text)}
tbody tr:last-child td{border-bottom:none}
tbody tr:hover td{background:var(--surface3)}
td.num{text-align:right;font-variant-numeric:tabular-nums;font-size:12px;color:var(--text2)}
td.total{font-weight:700;color:var(--text)}
.row-dark{background:var(--navy)!important}
.row-dark td{color:#ffffff!important;font-weight:700;font-size:11px;letter-spacing:.06em;text-transform:uppercase;border-bottom:none!important}
.row-dark td.num{color:rgba(255,255,255,.8)!important}
.row-dark td.num.accent{color:var(--accent)!important}
.row-accent{background:rgba(0,195,137,.04)!important}
.row-accent td{color:var(--accent2)!important;font-weight:600}

/* ─── INMUEBLES ─── */
.inmueble-tag{font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--accent2);background:rgba(0,195,137,.08);border:1px solid rgba(0,195,137,.2);border-radius:5px;padding:3px 8px}
.inmueble-name{font-size:13px;font-weight:700;color:var(--text);margin:10px 0}
.inmueble-list{list-style:none}
.inmueble-list li{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:11.5px}
.inmueble-list li:last-child{border-bottom:none}
.inmueble-list .prop{color:var(--text2)}
.inmueble-list .val{font-weight:600;color:var(--text);font-variant-numeric:tabular-nums}
.inmueble-footer{margin-top:12px;padding-top:12px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.inmueble-total-label{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);font-weight:600}
.inmueble-total-val{font-size:15px;font-weight:700;color:var(--accent2)}

/* ─── CONTROLES ─── */
.ctrl-section{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px}
.ctrl-label{font-size:10px;font-weight:700;color:var(--text3);margin-bottom:7px;text-transform:uppercase;letter-spacing:.08em}
.ctrl-row{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.ctrl-row input[type=range]{flex:1;-webkit-appearance:none;height:7px;background:var(--surface3);border-radius:10px;outline:none}
.ctrl-row input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;border-radius:50%;background:var(--accent);cursor:pointer;border:3px solid white;box-shadow:0 3px 8px rgba(0,195,137,.35)}
.ctrl-val{font-size:14px;font-weight:800;color:var(--accent2);min-width:130px;text-align:right;font-variant-numeric:tabular-nums}
.ctrl-input{width:100%;border:1px solid var(--border2);border-radius:7px;padding:7px 10px;text-align:center;font-size:12px;font-weight:600;color:var(--text);background:var(--surface2);font-family:inherit}
.ctrl-input:focus{outline:none;border-color:var(--accent)}

/* status box dinámico */
.status-box{padding:16px 18px;border-radius:10px;border:2px solid;transition:all .4s ease}
.status-box.neutral{background:var(--surface2);border-color:var(--border2)}
.status-box.positive{background:rgba(0,195,137,.07);border-color:rgba(0,195,137,.3)}
.status-box.negative{background:rgba(229,62,62,.06);border-color:rgba(229,62,62,.25)}
.sb-eyebrow{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--text3);margin-bottom:5px}
.sb-label{font-size:11.5px;font-weight:700;margin-bottom:4px}
.sb-label.positive{color:var(--accent2)}
.sb-label.negative{color:var(--danger)}
.sb-label.neutral{color:var(--text2)}
.sb-val{font-size:22px;font-weight:800;font-variant-numeric:tabular-nums;letter-spacing:-.02em}
.sb-val.positive{color:var(--accent2)}
.sb-val.negative{color:var(--danger)}
.sb-val.neutral{color:var(--text)}

/* panel dación oscuro */
.dacion-panel{background:var(--navy);border-radius:10px;padding:22px 24px;position:relative;overflow:hidden}
.dacion-panel::after{content:"";position:absolute;top:-30px;right:-30px;width:120px;height:120px;border-radius:50%;background:rgba(0,195,137,.08)}
.dacion-eyebrow{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--accent);margin-bottom:14px}
.dacion-row{display:flex;justify-content:space-between;align-items:flex-end;gap:12px}
.dacion-item-label{font-size:9px;text-transform:uppercase;letter-spacing:.07em;color:rgba(255,255,255,.38);margin-bottom:4px}
.dacion-val-lg{font-size:22px;font-weight:800;color:#ffffff;font-variant-numeric:tabular-nums;letter-spacing:-.02em}
.dacion-val-sm{font-size:15px;font-weight:600;color:rgba(255,255,255,.7);font-variant-numeric:tabular-nums}

/* impact boxes */
.impact-box{padding:14px 16px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;font-size:12px}
.impact-box-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px}
.impact-box-val{font-size:15px;font-weight:700;color:var(--text);font-variant-numeric:tabular-nums}

/* result rows */
.result-row{display:flex;justify-content:space-between;align-items:center;padding:9px 14px;border-radius:8px;margin-bottom:6px;font-size:12px}
.result-row.highlight{background:rgba(0,195,137,.07);border:1px solid rgba(0,195,137,.18)}
.result-row.warn{background:rgba(201,168,76,.07);border:1px solid rgba(201,168,76,.18)}
.result-label{color:var(--text2)}
.result-val{font-weight:700;font-variant-numeric:tabular-nums}
.result-val.green{color:var(--accent2)}
.result-val.gold{color:var(--gold)}

/* ─── BARS ─── */
.bar-row{margin-bottom:14px}
.bar-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;font-size:11.5px}
.bar-name{color:var(--text2)}
.bar-pct{font-weight:600;color:var(--text)}
.bar-track{height:7px;background:var(--surface3);border-radius:4px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;background:var(--accent)}
.bar-fill.gold{background:var(--gold)}

/* ─── CHECKPOINTS ─── */
.cp-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
.cp{display:flex;align-items:flex-start;gap:10px;padding:13px;background:var(--surface2);border-radius:8px;border:1px solid var(--border)}
.cp-icon{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cp-icon.green{background:rgba(0,195,137,.12);border:1px solid rgba(0,195,137,.3)}
.cp-icon.indigo{background:rgba(79,70,229,.1);border:1px solid rgba(79,70,229,.25)}
.cp-icon svg{width:12px;height:12px}
.cp-title{font-size:11.5px;font-weight:700;color:var(--text);margin-bottom:2px}
.cp-desc{font-size:10.5px;color:var(--text3);line-height:1.45}

/* ─── FORMULA ─── */
.formula-box{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:20px;text-align:center}
.formula-eyebrow{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:10px}
.formula-eq{font-size:17px;font-weight:700;color:var(--text);font-style:italic;padding:10px 0}
.formula-note{font-size:10px;color:var(--text3);line-height:1.5;margin-top:8px}

/* ─── PMO ─── */
.pmo{background:var(--navy);border-radius:14px;padding:32px;margin-top:20px;position:relative;overflow:hidden}
.pmo::before{content:"";position:absolute;top:-80px;right:-80px;width:300px;height:300px;border-radius:50%;background:rgba(0,195,137,.05)}
.pmo-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;flex-wrap:wrap;gap:12px}
.pmo-title{font-size:18px;font-weight:800;color:#ffffff;letter-spacing:-.02em;margin-bottom:4px}
.pmo-sub{font-size:11px;color:rgba(255,255,255,.32)}
.pmo-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin-bottom:28px}
.pmo-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:18px}
.pmo-card-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:rgba(255,255,255,.38);margin-bottom:12px}
.pmo-check{display:flex;align-items:center;gap:8px;font-size:11px;color:rgba(255,255,255,.6);padding:4px 0}
.pmo-check-dot{width:15px;height:15px;border-radius:50%;background:rgba(0,195,137,.2);border:1px solid rgba(0,195,137,.4);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pmo-check-dot svg{width:8px;height:8px}
.pmo-stat{display:flex;justify-content:space-between;align-items:center;font-size:11.5px;color:rgba(255,255,255,.45);padding:8px 0;border-bottom:1px solid rgba(255,255,255,.06)}
.pmo-stat:last-child{border-bottom:none}
.pmo-stat-val{font-weight:700;font-variant-numeric:tabular-nums}
.pmo-stat-val.white{color:#ffffff}
.pmo-stat-val.green{color:var(--accent)}
.pmo-status{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:600;color:var(--accent);background:rgba(0,195,137,.1);border:1px solid rgba(0,195,137,.2);border-radius:5px;padding:3px 9px;margin-top:10px}
.pmo-status-dot{width:5px;height:5px;border-radius:50%;background:var(--accent)}

/* firma */
.pmo-footer{border-top:1px solid rgba(255,255,255,.07);padding-top:20px;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px}
.firma-eyebrow{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.2em;color:var(--accent);margin-bottom:8px}
.firma-badges{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}
.firma-badge{background:rgba(79,70,229,.2);border:1px solid rgba(79,70,229,.4);border-radius:6px;padding:3px 9px;font-size:10px;font-weight:700;color:#a5b4fc;letter-spacing:.04em}
.firma-badge.green{background:rgba(0,195,137,.15);border-color:rgba(0,195,137,.3);color:var(--accent)}
.firma-text{font-size:11px;color:rgba(255,255,255,.38);line-height:1.9;font-family:monospace}
.firma-text strong{color:rgba(255,255,255,.72);font-weight:600}
.pmo-kpis{display:flex;gap:20px;flex-wrap:wrap}
.pmo-kpi{text-align:center}
.pmo-kpi-val{font-size:20px;font-weight:800;color:#ffffff;font-variant-numeric:tabular-nums;letter-spacing:-.02em}
.pmo-kpi-label{font-size:9px;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.35);margin-top:3px}

@media(max-width:700px){
  .kpi-grid,.kpi-grid-5{grid-template-columns:repeat(2,minmax(0,1fr))}
  .grid-3,.pmo-grid,.cp-grid{grid-template-columns:1fr}
  .row{flex-direction:column}
  .hdr{padding:22px 20px}
  .hdr-top{flex-direction:column}
  .hdr-meta{display:none}
  .dacion-row{flex-direction:column}
}
